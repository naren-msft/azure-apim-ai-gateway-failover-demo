# ============================================================
# Azure APIM AI Gateway + Foundry Agent Demo — Environment
# ============================================================
# Copy this file to .env and fill in your values after deployment.

# --- Azure AI Foundry Agent endpoint ---
# Format: https://<aiservices-id>.services.ai.azure.com/api/projects/<project-name>
AGENT_ENDPOINT=

# --- Agent ---
# Agent ID created by scripts/setup_agent.py
AGENT_ID=

# --- Azure APIM (optional — used by simulate_load.py) ---
APIM_GATEWAY_URL=https://<your-apim>.azure-api.net/openai
APIM_SUBSCRIPTION_KEY=
